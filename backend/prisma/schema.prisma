datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logo      String?
  industry  String?
  timezone  String    @default("UTC")
  currency  String    @default("USD")
  country   String?
  ownerId   String?
  taxType   String    @default("NONE") // "NONE", "GST", "VAT", "SALES_TAX"
  taxNumber String?   // GST/VAT registration number
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  categories       Category[]
  suppliers        Supplier[]
  warehouses       Warehouse[]
  auditLogs        AuditLog[]
  customers        Customer[]
  purchaseOrders   PurchaseOrder[]
  salesOrders      SalesOrder[]
  members          OrganizationMember[]
  invitations      Invitation[]
  Product          Product[]
  subscription     Subscription?
  cycleCounts      CycleCount[]
  Invoice          Invoice[]
  Bill             Bill[]
  PaymentReceived  PaymentReceived[]
  PaymentMade      PaymentMade[]
  integrations     Integration[]
  purchaseReturns  PurchaseReturn[]
  salesReturns     SalesReturn[]
  quotations       Quotation[]
  notifications    Notification[]
  taxRules         TaxRule[]
}


model Subscription {
  id                String       @id @default(uuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id])
  plan              String       @default("STARTER") // "STARTER", "PRO", "ENTERPRISE"
  status            String       @default("ACTIVE") // "ACTIVE", "PAST_DUE", "CANCELED"
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String?
  provider     AuthProvider @default(LOCAL)
  googleId     String?   @unique
  lastLogin    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  avatar       String?

  memberships OrganizationMember[]
  sessions    Session[]
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String // "OWNER", "ADMIN", "MANAGER", "STAFF"
  status         String       @default("ACTIVE") // "INVITED", "ACTIVE", "SUSPENDED", "LEFT"
  joinedAt       DateTime     @default(now())
  lastAccessedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String
  role           String // "ADMIN", "MANAGER", "STAFF"
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedBy      String? // User ID who sent the invite
  createdAt      DateTime     @default(now())

  @@unique([organizationId, email])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  refreshTokenHash String
  device           String?
  browser          String?
  ipAddress        String?
  location         String?
  expiresAt        DateTime
  lastUsedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
}

model Category {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  products Product[]

  @@unique([organizationId, name])
}

model Supplier {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  companyName    String
  email          String?
  phone          String?
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  products        Product[]
  purchaseOrders  PurchaseOrder[]
  ProductSupplier ProductSupplier[]
  priceHistory    SupplierPriceHistory[]
  Bill            Bill[]
  PaymentMade     PaymentMade[]
  purchaseReturns PurchaseReturn[]
}

model Warehouse {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  inventories Inventory[]
  cycleCounts CycleCount[]
}

model Product {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  sku            String
  barcode        String?
  name           String
  description    String?
  costPrice      Decimal      @db.Decimal(10, 2)
  sellingPrice   Decimal      @db.Decimal(10, 2)
  taxRate        Decimal      @default(0.00) @db.Decimal(5, 2)
  weight         Decimal?     @db.Decimal(8, 2)
  minimumStock   Int          @default(0)
  maximumStock   Int          @default(100)
  imageUrl       String?
  status         String       @default("ACTIVE") // "ACTIVE", "DRAFT", "ARCHIVED"

  qrCode       String?
  hasVariants  Boolean @default(false)
  isBundle     Boolean @default(false)
  baseUnit     String  @default("pcs")
  trackBatches Boolean @default(false)
  trackSerials Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  inventories        Inventory[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]

  images      ProductImage[]
  variants    ProductVariant[]
  units       ProductUnit[]
  suppliers   ProductSupplier[]
  notes       ProductNote[]
  attachments ProductAttachment[]
  Supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  supplierId  String?

  bundleItems          ProductBundleItem[]    @relation("BundleParent")
  componentOf          ProductBundleItem[]    @relation("BundleComponent")
  supplierPriceHistory SupplierPriceHistory[]
  InvoiceItem          InvoiceItem[]
  BillItem             BillItem[]
  purchaseReturnItems  PurchaseReturnItem[]
  salesReturnItems     SalesReturnItem[]
  quotationItems       QuotationItem[]

  @@unique([organizationId, sku])
}

model Inventory {
  id          String          @id @default(uuid())
  warehouseId String
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int             @default(0)
  reserved    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  transactions    InventoryTransaction[]
  batches         InventoryBatch[]
  serialNumbers   SerialNumber[]
  cycleCountItems CycleCountItem[]

  @@unique([warehouseId, productId, variantId])
}

enum TransactionType {
  PURCHASE
  SALE
  RETURN
  TRANSFER
  ADJUSTMENT
  DAMAGE
  EXPIRED
  OPENING_STOCK
}

model InventoryTransaction {
  id               String          @id @default(uuid())
  inventoryId      String
  inventory        Inventory       @relation(fields: [inventoryId], references: [id])
  type             TransactionType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  performedBy      String // User ID
  batchId          String?
  batch            InventoryBatch? @relation(fields: [batchId], references: [id])
  serialId         String?
  serial           SerialNumber?   @relation(fields: [serialId], references: [id])
  createdAt        DateTime        @default(now())
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  action         String
  entity         String
  entityId       String?
  metadata       String
  createdAt      DateTime     @default(now())
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  PENDING
  APPROVED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Customer {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String?
  phone          String?
  gst            String?
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  salesOrders     SalesOrder[]
  Invoice         Invoice[]
  PaymentReceived PaymentReceived[]
  salesReturns    SalesReturn[]
  quotations      Quotation[]
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  poNumber       String
  supplierId     String
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  status         PurchaseOrderStatus @default(DRAFT)
  totalAmount    Decimal             @db.Decimal(12, 2)
  shippingCost   Decimal             @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal             @default(0) @db.Decimal(10, 2)
  otherCosts     Decimal             @default(0) @db.Decimal(10, 2)
  expectedDate   DateTime?
  notes          String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  items PurchaseOrderItem[]
  Bill  Bill[]
  purchaseReturns PurchaseReturn[]

  @@unique([organizationId, poNumber])
}

model PurchaseOrderItem {
  id               String          @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant? @relation(fields: [variantId], references: [id])
  quantity         Int
  unitPrice        Decimal         @db.Decimal(10, 2)
  receivedQuantity Int             @default(0)
  landedUnitCost   Decimal?        @db.Decimal(10, 2)

  batches InventoryBatch[]
}

model SalesOrder {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  soNumber       String
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id])
  status         SalesOrderStatus @default(DRAFT)
  totalAmount    Decimal          @db.Decimal(12, 2)
  shippingCost   Decimal          @default(0) @db.Decimal(10, 2)
  taxAmount      Decimal          @default(0) @db.Decimal(10, 2)
  discountAmount Decimal          @default(0) @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  items   SalesOrderItem[]
  Invoice Invoice[]
  salesReturns SalesReturn[]

  @@unique([organizationId, soNumber])
}

model SalesOrderItem {
  id              String          @id @default(uuid())
  salesOrderId    String
  salesOrder      SalesOrder      @relation(fields: [salesOrderId], references: [id])
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  quantity        Int
  unitPrice       Decimal         @db.Decimal(10, 2)
  shippedQuantity Int             @default(0)
  cogs            Decimal?        @db.Decimal(10, 2)
  taxRuleId       String?
  taxRule         TaxRule?        @relation(fields: [taxRuleId], references: [id])
  taxAmount       Decimal         @default(0) @db.Decimal(10, 2)
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  name      String
  sku       String
  barcode   String?
  price     Decimal?  @db.Decimal(10, 2)
  cost      Decimal?  @db.Decimal(10, 2)
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  inventories        Inventory[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]
  InvoiceItem        InvoiceItem[]
  BillItem           BillItem[]
  purchaseReturnItems PurchaseReturnItem[]
  salesReturnItems    SalesReturnItem[]
  quotationItems      QuotationItem[]

  @@unique([productId, sku])
}

model ProductUnit {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  name            String
  conversionRatio Decimal  @db.Decimal(10, 4)
  barcode         String?
  createdAt       DateTime @default(now())
}

model ProductSupplier {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  supplierSku   String?
  supplierPrice Decimal  @db.Decimal(10, 2)
  leadTimeDays  Int?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  priceHistory SupplierPriceHistory[]

  @@unique([productId, supplierId])
}

model SupplierPriceHistory {
  id                String          @id @default(uuid())
  productId         String
  product           Product         @relation(fields: [productId], references: [id])
  supplierId        String
  supplier          Supplier        @relation(fields: [supplierId], references: [id])
  productSupplierId String
  productSupplier   ProductSupplier @relation(fields: [productSupplierId], references: [id])
  price             Decimal         @db.Decimal(10, 2)
  effectiveDate     DateTime        @default(now())
  recordedBy        String // User ID
  notes             String?
  createdAt         DateTime        @default(now())
}

model ProductNote {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  content   String
  createdBy String // User ID
  createdAt DateTime @default(now())
}

model ProductAttachment {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  fileName   String
  fileUrl    String
  fileSize   Int
  fileType   String
  uploadedBy String // User ID
  createdAt  DateTime @default(now())
}

model ProductBundleItem {
  id                 String   @id @default(uuid())
  bundleProductId    String
  bundleProduct      Product  @relation("BundleParent", fields: [bundleProductId], references: [id])
  componentProductId String
  componentProduct   Product  @relation("BundleComponent", fields: [componentProductId], references: [id])
  quantity           Int
  createdAt          DateTime @default(now())

  @@unique([bundleProductId, componentProductId])
}

model InventoryBatch {
  id                  String             @id @default(uuid())
  inventoryId         String
  inventory           Inventory          @relation(fields: [inventoryId], references: [id])
  purchaseOrderItemId String?
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  batchNumber         String
  quantity            Int
  manufacturingDate   DateTime?
  expiryDate          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  transactions InventoryTransaction[]

  @@unique([inventoryId, batchNumber])
}

enum SerialNumberStatus {
  AVAILABLE
  RESERVED
  SOLD
  RETURNED
}

model SerialNumber {
  id           String             @id @default(uuid())
  inventoryId  String
  inventory    Inventory          @relation(fields: [inventoryId], references: [id])
  serialNumber String
  status       SerialNumberStatus @default(AVAILABLE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  transactions InventoryTransaction[]

  @@unique([inventoryId, serialNumber])
}

enum CycleCountStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model CycleCount {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  warehouseId    String
  warehouse      Warehouse        @relation(fields: [warehouseId], references: [id])
  name           String
  status         CycleCountStatus @default(PENDING)
  assignedTo     String? // User ID
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  items CycleCountItem[]
}

model CycleCountItem {
  id               String     @id @default(uuid())
  cycleCountId     String
  cycleCount       CycleCount @relation(fields: [cycleCountId], references: [id])
  inventoryId      String
  inventory        Inventory  @relation(fields: [inventoryId], references: [id])
  expectedQuantity Int
  actualQuantity   Int?
  discrepancy      Int?
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([cycleCountId, inventoryId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  CANCELLED
}

model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  invoiceNumber  String
  salesOrderId   String?
  salesOrder     SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  status         InvoiceStatus @default(DRAFT)
  totalAmount    Decimal       @db.Decimal(12, 2)
  balanceDue     Decimal       @db.Decimal(12, 2)
  issuedDate     DateTime      @default(now())
  dueDate        DateTime?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  items    InvoiceItem[]
  payments PaymentReceived[]

  @@unique([organizationId, invoiceNumber])
}

model InvoiceItem {
  id          String          @id @default(uuid())
  invoiceId   String
  invoice     Invoice         @relation(fields: [invoiceId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  taxRuleId   String?
  taxRule     TaxRule?        @relation(fields: [taxRuleId], references: [id])
  taxAmount   Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount Decimal         @db.Decimal(12, 2)
}

enum BillStatus {
  DRAFT
  OPEN
  PARTIAL
  PAID
  CANCELLED
}

model Bill {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id])
  billNumber      String
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  status          BillStatus     @default(DRAFT)
  totalAmount     Decimal        @db.Decimal(12, 2)
  balanceDue      Decimal        @db.Decimal(12, 2)
  billDate        DateTime       @default(now())
  dueDate         DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  items    BillItem[]
  payments PaymentMade[]

  @@unique([organizationId, billNumber])
}

model BillItem {
  id          String          @id @default(uuid())
  billId      String
  bill        Bill            @relation(fields: [billId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  totalAmount Decimal         @db.Decimal(12, 2)
}

model PaymentReceived {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  invoiceId       String
  invoice         Invoice      @relation(fields: [invoiceId], references: [id])
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id])
  amount          Decimal      @db.Decimal(12, 2)
  paymentDate     DateTime     @default(now())
  paymentMethod   String // "CASH", "CARD", "BANK_TRANSFER", etc.
  referenceNumber String?
  notes           String?
  createdAt       DateTime     @default(now())
}

model PaymentMade {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  billId          String
  bill            Bill         @relation(fields: [billId], references: [id])
  supplierId      String
  supplier        Supplier     @relation(fields: [supplierId], references: [id])
  amount          Decimal      @db.Decimal(12, 2)
  paymentDate     DateTime     @default(now())
  paymentMethod   String // "CASH", "CARD", "BANK_TRANSFER", etc.
  referenceNumber String?
  notes           String?
  createdAt       DateTime     @default(now())
}

model Integration {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  provider       String       // "STRIPE", "SENDGRID", "QUICKBOOKS", "SHOPIFY"
  category       String       // "PAYMENT", "EMAIL", "ACCOUNTING", "E_COMMERCE"
  status         String       @default("INACTIVE") // "ACTIVE", "INACTIVE", "ERROR"
  config         String       // JSON string containing encrypted API keys/tokens
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
}

// ─────────────────────────────────────────────────────────────────────────────
// TAX RULES
// ─────────────────────────────────────────────────────────────────────────────

model TaxRule {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String       // e.g. "GST 18%", "VAT 20%"
  taxType        String       // "GST", "VAT", "SALES_TAX", "CUSTOM"
  rate           Decimal      @db.Decimal(5, 2) // percentage e.g. 18.00
  isDefault      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  invoiceItems    InvoiceItem[]
  salesOrderItems SalesOrderItem[]
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASE RETURNS
// ─────────────────────────────────────────────────────────────────────────────

model PurchaseReturn {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  returnNumber    String
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])
  status          String       @default("DRAFT") // "DRAFT", "APPROVED", "COMPLETED", "CANCELLED"
  reason          String?
  totalAmount     Decimal      @db.Decimal(12, 2)
  notes           String?
  createdBy       String       // User ID
  approvedBy      String?      // User ID
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  items PurchaseReturnItem[]

  @@unique([organizationId, returnNumber])
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturnId String
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id])
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant? @relation(fields: [variantId], references: [id])
  quantity         Int
  unitPrice        Decimal        @db.Decimal(10, 2)
  totalAmount      Decimal        @db.Decimal(12, 2)
}

// ─────────────────────────────────────────────────────────────────────────────
// SALES RETURNS
// ─────────────────────────────────────────────────────────────────────────────

model SalesReturn {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  returnNumber   String
  salesOrderId   String
  salesOrder     SalesOrder   @relation(fields: [salesOrderId], references: [id])
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  status         String       @default("DRAFT") // "DRAFT", "APPROVED", "COMPLETED", "CANCELLED"
  reason         String?
  totalAmount    Decimal      @db.Decimal(12, 2)
  notes          String?
  createdBy      String       // User ID
  approvedBy     String?      // User ID
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  items SalesReturnItem[]

  @@unique([organizationId, returnNumber])
}

model SalesReturnItem {
  id            String          @id @default(uuid())
  salesReturnId String
  salesReturn   SalesReturn     @relation(fields: [salesReturnId], references: [id])
  productId     String
  product       Product         @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  quantity      Int
  unitPrice     Decimal         @db.Decimal(10, 2)
  totalAmount   Decimal         @db.Decimal(12, 2)
}

// ─────────────────────────────────────────────────────────────────────────────
// QUOTATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Quotation {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  quoteNumber     String
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id])
  status          String       @default("DRAFT") // "DRAFT", "SENT", "ACCEPTED", "REJECTED", "EXPIRED"
  validUntil      DateTime?
  totalAmount     Decimal      @db.Decimal(12, 2)
  discountAmount  Decimal      @default(0) @db.Decimal(10, 2)
  taxAmount       Decimal      @default(0) @db.Decimal(10, 2)
  notes           String?
  convertedToSoId String?      // SalesOrder ID after conversion
  createdBy       String       // User ID
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  items QuotationItem[]

  @@unique([organizationId, quoteNumber])
}

model QuotationItem {
  id          String          @id @default(uuid())
  quotationId String
  quotation   Quotation       @relation(fields: [quotationId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  discount    Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount Decimal         @db.Decimal(12, 2)
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String       // Target user ID
  type           String       // "ORDER_STATUS", "LOW_STOCK", "RETURN_APPROVED", "QUOTE_ACCEPTED", etc.
  title          String
  message        String
  entityType     String?      // "SalesOrder", "PurchaseOrder", "Quotation", etc.
  entityId       String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

enum AuthProvider {
  LOCAL
  GOOGLE
}
