datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logo      String?
  industry  String?
  timezone  String    @default("UTC")
  currency  String    @default("USD")
  country   String?
  ownerId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  categories     Category[]
  suppliers      Supplier[]
  warehouses     Warehouse[]
  auditLogs      AuditLog[]
  customers      Customer[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  members        OrganizationMember[]
  invitations    Invitation[]
  Product        Product[]
  subscription   Subscription?
}

model Subscription {
  id                String       @id @default(uuid())
  organizationId    String       @unique
  organization      Organization @relation(fields: [organizationId], references: [id])
  plan              String       @default("STARTER") // "STARTER", "PRO", "ENTERPRISE"
  status            String       @default("ACTIVE") // "ACTIVE", "PAST_DUE", "CANCELED"
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String
  lastLogin    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  avatar       String?

  memberships OrganizationMember[]
  sessions    Session[]
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           String // "OWNER", "ADMIN", "MANAGER", "STAFF"
  status         String       @default("ACTIVE") // "INVITED", "ACTIVE", "SUSPENDED", "LEFT"
  joinedAt       DateTime     @default(now())
  lastAccessedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String
  role           String // "ADMIN", "MANAGER", "STAFF"
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedBy      String? // User ID who sent the invite
  createdAt      DateTime     @default(now())

  @@unique([organizationId, email])
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  refreshTokenHash String
  device           String?
  browser          String?
  ipAddress        String?
  location         String?
  expiresAt        DateTime
  lastUsedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
}

model Category {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  products Product[]

  @@unique([organizationId, name])
}

model Supplier {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  companyName    String
  email          String?
  phone          String?
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  products        Product[]
  purchaseOrders  PurchaseOrder[]
  ProductSupplier ProductSupplier[]
}

model Warehouse {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  inventories Inventory[]
}

model Product {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  sku            String
  barcode        String?
  name           String
  description    String?
  costPrice      Decimal      @db.Decimal(10, 2)
  sellingPrice   Decimal      @db.Decimal(10, 2)
  taxRate        Decimal      @default(0.00) @db.Decimal(5, 2)
  weight         Decimal?     @db.Decimal(8, 2)
  minimumStock   Int          @default(0)
  maximumStock   Int          @default(100)
  imageUrl       String?
  status         String       @default("ACTIVE") // "ACTIVE", "DRAFT", "ARCHIVED"

  qrCode      String?
  hasVariants Boolean @default(false)
  baseUnit    String  @default("pcs")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  inventories        Inventory[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]

  images      ProductImage[]
  variants    ProductVariant[]
  units       ProductUnit[]
  suppliers   ProductSupplier[]
  notes       ProductNote[]
  attachments ProductAttachment[]
  Supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  supplierId  String?

  @@unique([organizationId, sku])
}

model Inventory {
  id          String          @id @default(uuid())
  warehouseId String
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int             @default(0)
  reserved    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  transactions InventoryTransaction[]

  @@unique([warehouseId, productId, variantId])
}

enum TransactionType {
  PURCHASE
  SALE
  RETURN
  TRANSFER
  ADJUSTMENT
  DAMAGE
  EXPIRED
  OPENING_STOCK
}

model InventoryTransaction {
  id               String          @id @default(uuid())
  inventoryId      String
  inventory        Inventory       @relation(fields: [inventoryId], references: [id])
  type             TransactionType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  reason           String?
  performedBy      String // User ID
  createdAt        DateTime        @default(now())
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String?
  action         String
  entity         String
  entityId       String?
  metadata       String
  createdAt      DateTime     @default(now())
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  PENDING
  APPROVED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model Customer {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String?
  phone          String?
  gst            String?
  address        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  salesOrders SalesOrder[]
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id])
  poNumber       String
  supplierId     String
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  status         PurchaseOrderStatus @default(DRAFT)
  totalAmount    Decimal             @db.Decimal(12, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  items PurchaseOrderItem[]

  @@unique([organizationId, poNumber])
}

model PurchaseOrderItem {
  id               String          @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  productId        String
  product          Product         @relation(fields: [productId], references: [id])
  variantId        String?
  variant          ProductVariant? @relation(fields: [variantId], references: [id])
  quantity         Int
  unitPrice        Decimal         @db.Decimal(10, 2)
  receivedQuantity Int             @default(0)
}

model SalesOrder {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  soNumber       String
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id])
  status         SalesOrderStatus @default(DRAFT)
  totalAmount    Decimal          @db.Decimal(12, 2)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  items SalesOrderItem[]

  @@unique([organizationId, soNumber])
}

model SalesOrderItem {
  id              String          @id @default(uuid())
  salesOrderId    String
  salesOrder      SalesOrder      @relation(fields: [salesOrderId], references: [id])
  productId       String
  product         Product         @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant? @relation(fields: [variantId], references: [id])
  quantity        Int
  unitPrice       Decimal         @db.Decimal(10, 2)
  shippedQuantity Int             @default(0)
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ProductVariant {
  id        String    @id @default(uuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  name      String
  sku       String
  barcode   String?
  price     Decimal?  @db.Decimal(10, 2)
  cost      Decimal?  @db.Decimal(10, 2)
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  inventories        Inventory[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]

  @@unique([productId, sku])
}

model ProductUnit {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  name            String
  conversionRatio Decimal  @db.Decimal(10, 4)
  barcode         String?
  createdAt       DateTime @default(now())
}

model ProductSupplier {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  supplierSku   String?
  supplierPrice Decimal  @db.Decimal(10, 2)
  leadTimeDays  Int?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([productId, supplierId])
}

model ProductNote {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  content   String
  createdBy String // User ID
  createdAt DateTime @default(now())
}

model ProductAttachment {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  fileName   String
  fileUrl    String
  fileSize   Int
  fileType   String
  uploadedBy String // User ID
  createdAt  DateTime @default(now())
}
